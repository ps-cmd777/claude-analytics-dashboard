ANTHROPIC_API_KEY=<paste-your-key-from-console.anthropic.com-here>
DEFAULT_MODEL=claude-sonnet-4-6
MAX_UPLOAD_MB=50
CORS_ORIGINS=http://localhost:5173

# Set to "true" in production (requires HTTPS). Leave "false" for local dev.
COOKIE_SECURE=false

# Optional. Use Redis in production so rate limits are shared across workers.
# Example: redis://localhost:6379
# RATE_LIMIT_STORAGE_URI=memory://
